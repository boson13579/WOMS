# =============================================================================
# Smart Order Management — environment variables (12-Factor: Config).
#
# First-time setup:
#     cp .env.example .env
#     # then ROTATE every value below before the first `make up`
#
# .env is gitignored. Never commit real secrets.
#
# The placeholder values below are randomly generated at scaffold time and
# are SAFE to use only for local development. Generate fresh values with:
#     python -c "import secrets; print(secrets.token_hex(24))"
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
# =============================================================================

# --- Application -------------------------------------------------------------
APP_ENV=dev
LOG_LEVEL=INFO

# --- Database (PostgreSQL 15) ------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=445b6811a296eedce76404c273c89a662c8dce7899b9c3a8
POSTGRES_DB=smart_order
DATABASE_URL=postgresql+psycopg://postgres:445b6811a296eedce76404c273c89a662c8dce7899b9c3a8@localhost:5432/smart_order

# --- Redis / Celery ----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Optional overrides — defaults to REDIS_URL if unset.
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=

# --- Security ----------------------------------------------------------------
JWT_SECRET=K5CL9m3ynCLWhTN0_YXsEkmdVcMRaZ-u6OZGKVgN31nQKLetrCN8bVRRIfx8cy87
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_SECONDS=3600

# --- CORS --------------------------------------------------------------------
# Comma-separated list. Add the production frontend origin in prod env.
CORS_ORIGINS=http://localhost:5173
