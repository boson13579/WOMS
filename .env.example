# =============================================================================
# Smart Order Management — environment variables (12-Factor: Config).
#
# First-time setup:
#     cp .env.example .env
#     # then ROTATE every value below before the first `make up`
#
# .env is gitignored. Never commit real secrets.
#
# The placeholder values below are randomly generated at scaffold time and
# are SAFE to use only for local development. Generate fresh values with:
#     python -c "import secrets; print(secrets.token_hex(24))"
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
# =============================================================================

# --- Application -------------------------------------------------------------
APP_ENV=dev
LOG_LEVEL=INFO

# --- Database (PostgreSQL 15) ------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=445b6811a296eedce76404c273c89a662c8dce7899b9c3a8
POSTGRES_DB=smart_order
DATABASE_URL=postgresql+psycopg://postgres:445b6811a296eedce76404c273c89a662c8dce7899b9c3a8@localhost:5432/smart_order

# --- Redis / Celery ----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Optional overrides — defaults to REDIS_URL if unset.
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=

# --- Security ----------------------------------------------------------------
JWT_SECRET=K5CL9m3ynCLWhTN0_YXsEkmdVcMRaZ-u6OZGKVgN31nQKLetrCN8bVRRIfx8cy87
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_SECONDS=3600

# --- CORS --------------------------------------------------------------------
# Comma-separated list. Add the production frontend origin in prod env.
CORS_ORIGINS=http://localhost:5173

# --- Scheduler ---------------------------------------------------------------
# Business / operational knobs for the EDF scheduler. See
# docs/scheduling.md §2.4 for the full picture and the deployment caveats
# (changing CAPACITY / HORIZON in a running cluster requires a Redis
# schedule:state rebuild — call POST /api/v1/schedule/rebuild after
# bouncing workers).

# Daily wafer production cap; segment trees use this as the per-day capacity.
SCHEDULER_DAILY_CAPACITY=10000

# How many days ahead the scheduler accepts deadlines for; segment trees are
# sized by this. 30 days = 1 month rolling horizon.
SCHEDULER_HORIZON_DAYS=30

# advance_day_task / rebuild_schedule_task wait at most this long (seconds)
# for any in-flight run_scheduling_task to finish before proceeding.
SCHEDULER_RUN_WAIT_TIMEOUT_SECONDS=300

# Polling cadence (seconds) inside _wait_for_idle_run.
SCHEDULER_RUN_WAIT_POLL_INTERVAL_SECONDS=2

# TTL (seconds) on schedule:waiter_pending — if a waiter dies before its
# finally clears the flag, future run_scheduling_task invocations resume
# normal re-trigger after this expiry. Should comfortably exceed
# SCHEDULER_RUN_WAIT_TIMEOUT_SECONDS plus the worst-case waiter body time.
SCHEDULER_WAITER_FLAG_TTL_SECONDS=600
